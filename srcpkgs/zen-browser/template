# Template file for 'zen-browser'
pkgname=zen-browser
_desktopname=zen
version=1.19.3b
revision=1
archs="x86_64"
short_desc="Performance oriented Firefox-based web browser"
maintainer="Rain Xelelo <rXelelo@outlook.com>"
license="MIT"
homepage="https://github.com/zen-browser/desktop"
depends="gtk+3 libXt dbus-glib nss ffmpeg"

distfiles="https://github.com/zen-browser/desktop/releases/download/$version/zen.linux-x86_64.tar.xz"
checksum="3b03eaeecfb222ecd62d37b9d6d409d704ce2437ff8286626e17b0289eb60c91"

do_install() {
	# Main application directory
	vmkdir opt/${pkgname}
	vmkdir usr/bin
    vmkdir usr/share/applications

	# Copy all extracted files
	cp -r ${wrksrc}/* ${DESTDIR}/opt/${pkgname}/

    # Launchers
    vinstall ${FILESDIR}/zen-browser.sh 755 usr/bin zen-browser

	# Desktop entries
	vinstall ${FILESDIR}/zen.desktop 644 usr/share/applications zen.desktop

	# Icons
	for i in 16 32 48 64 128; do
    vmkdir /usr/share/icons/hicolor/${i}x${i}/apps/
    ln -s /opt/${pkgname}/browser/chrome/icons/default/default${i}.png \
          ${DESTDIR}/usr/share/icons/hicolor/${i}x${i}/apps/${pkgname}.png
    done
    
    # Use system-provided dictionaries
    ln -Ts /usr/share/hunspell ${DESTDIR}/opt/$pkgname/dictionaries
    ln -Ts /usr/share/hyphen ${DESTDIR}/opt/$pkgname/hyphenation

    # Use system certificates
    ln -sf /usr/lib/libnssckbi.so ${DESTDIR}/opt/$pkgname/libnssckbi.so

    # Disable update checks
    vmkdir opt/${pkgname}/distribution
    vinstall ${FILESDIR}/policies.json 644 opt/${pkgname}/distribution
}

# Template file for 'hyprsunset'
pkgname=hyprsunset
version=0.3.3
revision=2
build_style=cmake
configure_args=" --no-warn-unused-cli -DCMAKE_BUILD_TYPE=Release"
hostmakedepends="cmake pkg-config git"
makedepends="
	hyprland-protocols
	hyprwayland-scanner
    hyprutils-devel
	hyprlang-devel
	wayland-devel
	wayland-protocols
"
short_desc="An application to enable a blue-light filter on Hyprland"
maintainer="hesam-init <hesam.init@gmail.com>"
license="BSD-3-Clause"
homepage="https://github.com/hyprwm/hyprsunset"
distfiles="https://github.com/hyprwm/hyprsunset/archive/refs/tags/v${version}.tar.gz"
checksum=cf2b3cc836bdeb7ac3ae78cf98e8cc4a06093e8d8215ff4da2380843dcf1a5dc

build_options="clang gcc"
build_options_default="clang"
desc_option_clang="Use clang to build"
desc_option_gcc="Use gcc to build"

if [ "$build_option_gcc" ]; then
	hostmakedepends+=" gcc"
	makedepends+=" libgcc-devel fmt-devel"
fi

if [ "$build_option_clang" ]; then
	hostmakedepends+=" clang21"
	makedepends+=""
fi

pre_configure() {
	if [ "$build_option_clang" ]; then
		export CC=clang
		export CXX=clang++

		configure_args+=" -DCMAKE_C_COMPILER=$CC -DCMAKE_CXX_COMPILER=$CXX -DCMAKE_CXX_STANDARD=23 -DCMAKE_CXX_FLAGS=-stdlib=libstdc++ -DCMAKE_EXE_LINKER_FLAGS=-stdlib=libstdc++ -DCMAKE_SHARED_LINKER_FLAGS=-stdlib=libstdc++"
	fi
}

post_install() {
	vlicense LICENSE
}

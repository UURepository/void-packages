# Template file for 'fresh-editor'
pkgname=fresh-editor
version=0.4.1
revision=1
short_desc="A lightweight, fast terminal-based text editor with LSP support and TypeScript plugins"
maintainer="Rain Xelelo <rXelelo@outlook.com>"
license="GPL-2.0-only"
homepage="https://sinelaw.github.io/fresh/"
distfiles="https://github.com/sinelaw/fresh/archive/refs/tags/v${version}.tar.gz"
checksum=a61a98a2057729ead79183f39357f8bb034cbd3f919342d4395247aa79a4025c

build_style=cargo
hostmakedepends="cargo clang pkg-config"
makedepends="oniguruma-devel"
depends="glibc libgcc oniguruma"

do_install() {
    vinstall target/x86_64-unknown-linux-gnu/release/fresh 755 usr/libexec/${pkgname}
    vcopy crates/fresh-editor/plugins usr/libexec/${pkgname}/
    vcopy crates/fresh-editor/keymaps usr/libexec/${pkgname}/

    vmkdir usr/bin
    ln -sf /usr/libexec/${pkgname}/fresh "${DESTDIR}/usr/bin/fresh"

    vinstall crates/fresh-editor/resources/fresh.desktop 644 \
        usr/share/applications

    # 4. Hicolor icons (Allowed in usr/share/icons)
    for icon in crates/fresh-gui/resources/icon_*x*.png; do
        size=${icon##*icon_}
        size=${size%.png}
        vinstall "$icon" 644 \
            "usr/share/icons/hicolor/${size}/apps" fresh.png
    done

    vman crates/fresh-editor/resources/fresh.1
    vdoc README.md
    vlicense LICENSE
}
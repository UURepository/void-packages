# Template file for 'ghostty'
pkgname=ghostty
version=1.3.1
revision=1
build_style=gnu-configure
hostmakedepends="pkg-config glib-devel pandoc gettext blueprint-compiler zig15.2"
makedepends="fontconfig-devel freetype-devel harfbuzz-devel gtk4-devel libadwaita-devel gtk4-layer-shell-devel"
depends="ghostty-terminfo-${version}_${revision}"
short_desc="Fast and feature-rich terminal emulator that uses GPU acceleration"
maintainer="Duncaen <duncaen@voidlinux.org>"
license="MIT"
homepage="https://ghostty.org/"
distfiles="https://github.com/ghostty-org/ghostty/archive/refs/tags/v${version}.tar.gz"
checksum=265837d3026b433f0e6b4e49d43153b915b0a19513f7edd8a8e693c559bd415b

case "${XBPS_TARGET_MACHINE}" in
	armv*) broken="src/apprt/gtk/cgroup.zig:70:14: error: expected type 'usize', found 'u64'" ;;
esac

do_configure() {
	:
}

do_build() {
	zig build \
		-Doptimize=ReleaseFast \
		-Dpie \
		-Dversion-string=${version} \
		-fsys=freetype \
		-fsys=fontconfig \
		-fsys=harfbuzz
}

do_install() {
	zig build install \
		-Doptimize=ReleaseFast \
		-Dpie \
		-Dversion-string=${version} \
		-fsys=freetype \
		-fsys=fontconfig \
		-fsys=harfbuzz \
		--prefix ${DESTDIR}/usr
}


post_install() {
	vlicense LICENSE
	rm -f ${DESTDIR}/usr/share/man/.placeholder
}

ghostty-terminfo_package() {
	short_desc+=" - terminfo data"
	pkg_install() {
		vmove usr/share/terminfo
	}
}

# Template file for 'hyprgraphics'
pkgname=hyprgraphics
version=0.5.1
revision=2
build_style=cmake
configure_args=" --no-warn-unused-cli -DCMAKE_BUILD_TYPE=Release"
hostmakedepends="cmake pkg-config"
makedepends="
   hyprutils-devel
   libspng
   libjpeg-turbo-devel
   libwebp-devel
   libjxl-devel
   pixman-devel
   cairo-devel
   file-devel
   MesaLib-devel
   pango-devel
   librsvg-devel
   fmt-devel
"
short_desc="hyprland graphics resources and utilities"
maintainer="hesam-init <hesam.init@gmail.com>"
license="BSD-3-Clause"
homepage="https://github.com/hyprwm/hyprgraphics"
distfiles="https://github.com/hyprwm/hyprgraphics/archive/refs/tags/v${version}.tar.gz"
checksum=861ecaad872835922dd5745a612d7a4cc7bfc4babb1d06bc92bc63c2ac013b74

build_options="clang gcc"
build_options_default="clang"
desc_option_clang="Use clang to build"
desc_option_gcc="Use gcc to build"

if [ "$build_option_gcc" ]; then
   hostmakedepends+=" gcc"
   makedepends+=" libgcc-devel fmt-devel"
fi

if [ "$build_option_clang" ]; then
   hostmakedepends+=" clang21"
fi

_apply_patch() {
   local args="$1" pname="$(basename $2)"

   if [ ! -f ".${pname}_done" ]; then
      patch -N $args -i $2
      touch .${pname}_done
   fi
}

pre_configure() {
   if [ "$build_option_clang" ]; then
      export CC=clang
      export CXX=clang++
      export CXXFLAGS="${CXXFLAGS} -stdlib=libstdc++"
      export LDFLAGS="${LDFLAGS} -stdlib=libstdc++"

      configure_args+=" -DCMAKE_C_COMPILER=$CC -DCMAKE_CXX_COMPILER=$CXX \
         -DCMAKE_CXX_STANDARD=23 \
         -DCMAKE_CXX_FLAGS=-stdlib=libstdc++ -DCMAKE_EXE_LINKER_FLAGS=-stdlib=libstdc++ -DCMAKE_SHARED_LINKER_FLAGS=-stdlib=libstdc++"
   fi
   # Add fmt dependency for GCC
    sed -i '/find_package(PkgConfig REQUIRED)/a find_package(fmt REQUIRED)' CMakeLists.txt
    sed -i 's/target_link_libraries(hyprgraphics PkgConfig::deps \(.*\))/target_link_libraries(hyprgraphics PkgConfig::deps fmt::fmt \1)/' CMakeLists.txt
    sed -i 's/target_link_libraries(hyprgraphics_image PRIVATE hyprgraphics PkgConfig::deps)/target_link_libraries(hyprgraphics_image PRIVATE hyprgraphics PkgConfig::deps fmt::fmt)/' CMakeLists.txt
    # Replace std::println with fmt::print
    sed -i 's/#include <print>/#include <fmt\/core.h>\n#include <algorithm>/' tests/image.cpp
    sed -i 's/std::println/fmt::print/g' tests/image.cpp
}

post_install() {
   vlicense LICENSE
}

# Template file for 'hyprwayland-scanner'
pkgname=hyprwayland-scanner
version=0.4.6
revision=1
build_style=cmake
configure_args=" --no-warn-unused-cli -DCMAKE_BUILD_TYPE=Release"
hostmakedepends="cmake pkg-config"
makedepends="pugixml-devel"
short_desc="Hyprland's implementation of wayland-scanner in/for C++"
maintainer="hesam-init <hesam.init@gmail.com>"
license="BSD-3-Clause"
homepage="https://github.com/hyprwm/hyprwayland-scanner"
distfiles="https://github.com/hyprwm/hyprwayland-scanner/archive/refs/tags/v${version}.tar.gz"
checksum=05f55fd1a20d8ca81b5030980fdb7c87147749230145bdb3745af2741d617f5c

build_options="clang gcc"
build_options_default="clang"
desc_option_clang="Use clang to build"
desc_option_gcc="Use gcc to build"

if [ "$build_option_gcc" ]; then
   hostmakedepends+=" gcc"
   makedepends+=" libgcc-devel fmt-devel"
fi

if [ "$build_option_clang" ]; then
   hostmakedepends+=" clang21"
   makedepends+=""
fi

pre_configure() {
   if [ "$build_option_clang" ]; then
      export CC=clang
      export CXX=clang++

      configure_args+=" -DCMAKE_C_COMPILER=$CC -DCMAKE_CXX_COMPILER=$CXX -DCMAKE_CXX_STANDARD=23 -DCMAKE_CXX_FLAGS=-stdlib=libstdc++ -DCMAKE_EXE_LINKER_FLAGS=-stdlib=libstdc++ -DCMAKE_SHARED_LINKER_FLAGS=-stdlib=libstdc++"
   fi
}

post_install() {
   vlicense LICENSE
}

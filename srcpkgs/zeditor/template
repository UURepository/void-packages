revision=1
short_desc="Code at the speed of thought – Zed is a high-performance, multiplayer code editor from the creators of Atom and Tree-sitter. "
maintainer="Rain Xelelo <rXelelo@outlook.com"
license="GPL-3.0-only"
homepage="https://zed.dev"
distfiles="https://github.com/zed-industries/zed/releases/download/v${version}/zed-linux-x86_64.tar.gz"

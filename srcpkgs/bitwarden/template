# Template file for 'bitwarden'
pkgname=bitwarden
version=2026.5.0
revision=1
short_desc="A secure and free password manager for all of your devices"
maintainer="Rain Xelelo <rXelelo@outlook.com>"
license="GPL-3.0-only"
homepage="https://bitwarden.com"
distfiles="https://github.com/bitwarden/clients/releases/download/desktop-v${version}/Bitwarden-${version}-amd64.deb"
checksum="2ea59874bac7f67f5663828d028449168050d4538b5e6adea69e13b199249226"
hostmakedepends="desktop-file-utils"
depends="alsa-lib gtk+3 libnotify libXtst libXScrnSaver nss"
nopie=yes
nostrip=yes

do_install() {
    # extract deb
    cp -r ./* "${DESTDIR}/"

    # Fix exec in desktop file
    desktop-file-edit --set-key=Exec --set-value="bitwarden %U" \
        "${DESTDIR}/usr/share/applications/bitwarden.desktop"

    # apparmor profile symlink
    vmkdir etc/apparmor.d
    ln -s /opt/Bitwarden/resources/apparmor-profile \
        "${DESTDIR}/etc/apparmor.d/bitwarden"

    # chrome sandbox needs setuid
    chmod 04755 "${DESTDIR}/opt/Bitwarden/chrome-sandbox"

    # launcher script
    vinstall ${FILESDIR}/bitwarden.sh 755 usr/bin bitwarden

    # Clean out unwanted upstream musl binaries that break glibc shlibs tracking
    find "${DESTDIR}" -type f -name "*musl*" -delete
}
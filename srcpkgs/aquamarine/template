# Template file for 'aquamarine'
pkgname=aquamarine
version=0.12.1
revision=1
build_style=cmake
configure_args=" --no-warn-unused-cli -DCMAKE_BUILD_TYPE=Release"
hostmakedepends="cmake pkg-config"
makedepends="
	hyprutils-devel
	hyprwayland-scanner
	hwids
	libdisplay-info-devel
	libdrm-devel
	libgbm-devel
	libglvnd-devel
	libinput-devel
	libseat-devel
	libudev-devel
	pixman-devel
	wayland-devel
	wayland-protocols
"
short_desc="Aquamarine is a very light linux rendering backend library"
maintainer="hesam-init <hesam.init@gmail.com>"
license="LGPL-3.0-only"
homepage="https://hyprland.org/hyprlang/index.html"
changelog="https://github.com/hyprwm/aquamarine/releases"
distfiles="https://github.com/hyprwm/aquamarine/archive/refs/tags/v${version}.tar.gz"
checksum=80120257c983e18dec78c4df03246931b1bca1e44e50fb41ca21bad772479bd9

build_options="clang gcc"
build_options_default="clang"
desc_option_clang="Use clang to build"
desc_option_gcc="Use gcc to build"

if [ "$build_option_gcc" ]; then
   hostmakedepends+=" gcc"
   makedepends+=" libgcc-devel fmt-devel"
fi

if [ "$build_option_clang" ]; then
   hostmakedepends+=" clang21"
   makedepends+=""
fi

pre_configure() {
   if [ "$build_option_clang" ]; then
      export CC=clang
      export CXX=clang++

      configure_args+=" -DCMAKE_C_COMPILER=$CC -DCMAKE_CXX_COMPILER=$CXX -DCMAKE_CXX_STANDARD=23 -DCMAKE_CXX_FLAGS=-stdlib=libstdc++ -DCMAKE_EXE_LINKER_FLAGS=-stdlib=libstdc++ -DCMAKE_SHARED_LINKER_FLAGS=-stdlib=libstdc++"
   fi
}

post_install() {
   vlicense LICENSE
}

aquamarine-devel_package() {
   depends="aquamarine-${version}_${revision}"
   short_desc+=" - development files"

   pkg_install() {
      vmove usr/include
      vmove "usr/lib/*.so"
      vmove usr/lib/pkgconfig
   }
}

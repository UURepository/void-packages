# Template file for 'hyprlang'
pkgname=hyprlang
version=0.6.8
revision=2
build_style=cmake
configure_args=" --no-warn-unused-cli -DCMAKE_BUILD_TYPE=Release"
hostmakedepends="cmake pkg-config"
makedepends="hyprutils-devel fmt-devel"
short_desc="Official implementation library for the hypr config language"
maintainer="hesam-init <hesam.init@gmail.com>"
license="LGPL-3.0-only"
homepage="https://hyprland.org/hyprlang/index.html"
changelog="https://github.com/hyprwm/hyprlang/releases"
distfiles="https://github.com/hyprwm/hyprlang/archive/refs/tags/v${version}.tar.gz"
checksum=d10a0778b646e04d83e8b90cc0f764fb96958c01a15c3c0678d95a40fc647ed5

build_options="clang gcc"
build_options_default="clang"
desc_option_clang="Use clang to build"
desc_option_gcc="Use gcc to build"

if [ "$build_option_gcc" ]; then
   hostmakedepends+=" gcc"
   makedepends+=" libgcc-devel fmt-devel"
fi

if [ "$build_option_clang" ]; then
   hostmakedepends+=" clang21"
   makedepends+=""
fi

_apply_patch() {
   local args="$1" pname="$(basename $2)"

   if [ ! -f ".${pname}_done" ]; then
      patch -N $args -i $2
      touch .${pname}_done
   fi
}

pre_configure() {
   if [ "$build_option_clang" ]; then
      export CC=clang
      export CXX=clang++

      configure_args+=" -DCMAKE_C_COMPILER=$CC -DCMAKE_CXX_COMPILER=$CXX -DCMAKE_CXX_STANDARD=23 -DCMAKE_CXX_FLAGS=-stdlib=libstdc++ -DCMAKE_EXE_LINKER_FLAGS=-stdlib=libstdc++ -DCMAKE_SHARED_LINKER_FLAGS=-stdlib=libstdc++"
   fi
   # Add fmt dependency for GCC (no std::println in GCC's C++23)
    sed -i '/find_package(PkgConfig REQUIRED)/a find_package(fmt REQUIRED)' CMakeLists.txt
    sed -i 's/target_link_libraries(hyprlang PkgConfig::deps)/target_link_libraries(hyprlang PkgConfig::deps fmt::fmt)/' CMakeLists.txt
}

hyprlang-devel_package() {
   depends="hyprlang-${version}_${revision}"
   short_desc+=" - development files"

   pkg_install() {
      vmove usr/include
      vmove "usr/lib/*.so"
      vmove usr/lib/pkgconfig
   }
}

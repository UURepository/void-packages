# Template for 'pear-desktop'
pkgname=pear-desktop
version=3.11.0
revision=2
archs="x86_64"
short_desc="Extension for music player"
maintainer="Rain Xelelo <rxelelo@outlook.com>"
license="MIT"
homepage="https://github.com/pear-devs/pear-desktop"
depends="gtk+3 libsecret nss"
distfiles="https://github.com/pear-devs/pear-desktop/releases/download/v${version}/youtube-music_${version}_amd64.deb"
checksum="db20c40bdcc558aaa85d6d5c20a3ec1e32795fcd6ffaa7e4f99757004736face"

do_install() {
    cp -r ${wrksrc}/usr ${DESTDIR}/
    cp -r ${wrksrc}/opt ${DESTDIR}/

    sed -i 's|^Exec=.*|Exec=youtube-music %U|' \
        ${DESTDIR}/usr/share/applications/youtube-music.desktop

    vmkdir usr/bin
    cat > ${DESTDIR}/usr/bin/youtube-music << 'EOF'
#!/bin/bash

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"

# Allow users to override command-line options
if [[ -f "$XDG_CONFIG_HOME/youtube-music-flags.conf" ]]; then
   YOUTUBE_MUSIC_USER_FLAGS="$(grep -v '^#' "$XDG_CONFIG_HOME/youtube-music-flags.conf")"
fi

# Launch
export ELECTRON_IS_DEV=0
exec /opt/YouTube\ Music/youtube-music $YOUTUBE_MUSIC_USER_FLAGS "$@"
EOF
    chmod 755 ${DESTDIR}/usr/bin/youtube-music
}
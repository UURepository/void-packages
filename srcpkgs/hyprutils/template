# Template file for 'hyprutils'
pkgname=hyprutils
version=0.13.1
revision=1
build_style=cmake
hostmakedepends="pkg-config"
configure_args=" --no-warn-unused-cli -DCMAKE_BUILD_TYPE=Release"
hostmakedepends="cmake pkg-config"
makedepends="pixman-devel"
short_desc="A small C++ library used across the Hypr* ecosystem"
maintainer="hesam-init <hesam.init@gmail.com>"
license="BSD-3-Clause"
homepage="https://github.com/hyprwm/hyprutils"
distfiles="https://github.com/hyprwm/hyprutils/archive/refs/tags/v${version}.tar.gz"
checksum=480ee026105deea64a24eb96d80cabe54b357594ce36cb05c021ea226c69aede

build_options="clang gcc"
build_options_default="clang"
desc_option_clang="Use clang to build"
desc_option_gcc="Use gcc to build"

if [ "$build_option_gcc" ]; then
   hostmakedepends+=" gcc"
   makedepends+=" libgcc-devel"
fi

if [ "$build_option_clang" ]; then
   hostmakedepends+=" clang21"
fi

pre_configure() {
   if [ "$build_option_clang" ]; then
      export CC=clang
      export CXX=clang++
      export CXXFLAGS="${CXXFLAGS} -stdlib=libstdc++"
      export LDFLAGS="${LDFLAGS} -stdlib=libstdc++"

      configure_args+=" -DCMAKE_C_COMPILER=$CC -DCMAKE_CXX_COMPILER=$CXX \
         -DCMAKE_CXX_STANDARD=23 \
         -DCMAKE_CXX_FLAGS=-stdlib=libstdc++ -DCMAKE_EXE_LINKER_FLAGS=-stdlib=libstdc++ -DCMAKE_SHARED_LINKER_FLAGS=-stdlib=libstdc++"
   fi
}

post_install() {
   vlicense LICENSE
}

hyprutils-devel_package() {
   depends="hyprutils-${version}_${revision}"
   short_desc+=" - development files"

   pkg_install() {
      vmove usr/include
      vmove "usr/lib/*.so"
      vmove usr/lib/pkgconfig
   }
}

# Template file for 'hyprpaper'
pkgname=hyprpaper
version=0.8.4
revision=2
build_style=cmake
configure_args=" --no-warn-unused-cli -DCMAKE_BUILD_TYPE=Release"
hostmakedepends="pkg-config cmake"
makedepends="
	hyprwayland-scanner
	hyprgraphics
    hyprutils-devel
 	hyprland-protocols
	hyprlang-devel
	hyprwire
	hyprtoolkit
	aquamarine-devel
	pango-devel
	cairo-devel
	libjpeg-turbo-devel
	wayland-devel
	wayland-protocols
	wlroots-devel
	libwebp-devel
	file-devel
"
short_desc="Fast wallpaper utility for wlroots compositors with IPC controls"
maintainer="hesam-init <hesam.init@gmail.com>"
license="BSD-3-Clause"
homepage="https://github.com/hyprwm/hyprpaper"
distfiles="https://github.com/hyprwm/hyprpaper/archive/refs/tags/v${version}.tar.gz"
checksum=4912c7aede303918f38a3fc6b294429e2d541b639ebba67bcab58d1d367ea360

build_options="clang gcc"
build_options_default="clang"
desc_option_clang="Use clang to build"
desc_option_gcc="Use gcc to build"

if [ "$build_option_gcc" ]; then
	hostmakedepends+=" gcc"
	makedepends+=" libgcc-devel fmt-devel"
fi

if [ "$build_option_clang" ]; then
	hostmakedepends+=" clang21"
	makedepends+=""
fi

_apply_patch() {
	local args="$1" pname="$(basename $2)"

	if [ ! -f ".${pname}_done" ]; then
		patch -N $args -i $2
		touch .${pname}_done
	fi
}

pre_configure() {
	#if [ "$build_option_gcc" ]; then
	#	_apply_patch -p1 ${FILESDIR}/gcc.patch
	#fi

	if [ "$build_option_clang" ]; then
		export CC=clang
		export CXX=clang++

		configure_args+=" -DCMAKE_C_COMPILER=$CC -DCMAKE_CXX_COMPILER=$CXX -DCMAKE_CXX_STANDARD=23 -DCMAKE_CXX_FLAGS=-stdlib=libstdc++ -DCMAKE_EXE_LINKER_FLAGS=-stdlib=libstdc++ -DCMAKE_SHARED_LINKER_FLAGS=-stdlib=libstdc++"
	fi
	sed -i 's/m_settings\.append_range(std::move(s));/m_settings.insert(m_settings.end(), std::make_move_iterator(s.begin()), std::make_move_iterator(s.end()));/' src/config/WallpaperMatcher.cpp
}

post_install() {
	vlicense LICENSE
}

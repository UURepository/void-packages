	libxkbcommon-devel
	pango-devel
	wayland-devel
	wayland-protocols
	xorg-server-xwayland
	udis86-devel
	re2-devel
	xcb-util-errors-devel
	xcb-util-renderutil-devel
	xcb-util-wm-devel
	xcb-util-image-devel
	xorg-server-xwayland
	muparser-devel
	hyprwire
	hyprland-guiutils
	glslang-devel
	SPIRV-Tools-devel
	lcms2-devel
	lua55-devel
"
depends="
	hyprlang
	hyprwayland-scanner
	lcms2
	hyprgraphics
	hyprutils
	hyprcursor
	cairo
	glslang

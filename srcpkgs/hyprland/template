	wayland-protocols
	xcb-proto
	xcb-util
	xcb-util-keysyms
	xorg-server-xwayland
	re2
	muparser
"
short_desc="Dynamic tiling Wayland compositor that doesn't sacrifice on its looks"
maintainer="hesam-init <hesam.init@gmail.com>"
license="BSD-3-Clause"
homepage="https://hyprland.org/"
changelog="https://github.com/hyprwm/Hyprland/releases"
distfiles="https://github.com/hyprwm/Hyprland/releases/download/v${version}/source-v${version}.tar.gz"
checksum=10cdda47e6a42e603a646ffda89c9fca0628c3a8211e2fbbee02f6282effe30b

build_options="clang gcc"
build_options_default="clang"
desc_option_clang="Use clang to build"
desc_option_gcc="Use gcc to build"

if [ "$build_option_gcc" ]; then
	hostmakedepends+=" gcc"
	makedepends+=" libgcc-devel fmt-devel"
fi

if [ "$build_option_clang" ]; then
	hostmakedepends+=" clang21"
	makedepends+=""
fi

if [ "$XBPS_TARGET_LIBC" = "glibc" ]; then
	makedepends+=" glaze"
fi

if [ "$XBPS_TARGET_LIBC" = "musl" ]; then
	configure_args+=" -DCMAKE_CXX_FLAGS=\"-lexecinfo\""
	makedepends+=" libexecinfo-devel"
	depends+=" libexecinfo"
fi

_apply_patch() {
	local args="$1" pname="$(basename $2)"

	if [ ! -f ".${pname}_done" ]; then
		patch -N $args -i $2
		touch .${pname}_done
	fi
}

pre_configure() {
    # Fix std::numbers missing include
    sed -i '1s/^/#include <numbers>\n/' ${wrksrc}/src/helpers/cm/ColorManagement.cpp

    # Fix string + string_view concatenation (libstdc++ stricter than libc++)
    # Wrap string_view args in std::string() wherever + operator is used
    find ${wrksrc}/src ${wrksrc}/hyprctl -name "*.cpp" -o -name "*.hpp" | \
        xargs sed -i \
            -e 's/std::string{"0x"} + value/std::string{"0x"} + std::string(value)/g' \
            -e 's/+ filename;/+ std::string(filename);/g' \
            -e 's/instanceSignature + \//std::string(instanceSignature) + \//g'
	
	# Fix insert_range (C++23, not in libstdc++14)
	sed -i 's/requestedModes\.insert_range(requestedModes\.end(), sortedModes | std::views::reverse);/requestedModes.insert(requestedModes.end(), sortedModes.rbegin(), sortedModes.rend());/' \
    ${wrksrc}/src/helpers/Monitor.cpp

    if [ "$build_option_clang" ]; then
        export CC=clang
        export CXX=clang++
        configure_args+=" -DCMAKE_C_COMPILER=$CC -DCMAKE_CXX_COMPILER=$CXX \
            -DCMAKE_CXX_STANDARD=23 -DCMAKE_CXX_STANDARD_REQUIRED=ON \
            -DCMAKE_CXX_FLAGS=-stdlib=libstdc++ \
            -DCMAKE_EXE_LINKER_FLAGS=-stdlib=libstdc++ \
            -DCMAKE_SHARED_LINKER_FLAGS=-stdlib=libstdc++"
    fi
}

post_install() {
	vlicense LICENSE
    
    vinstall ${wrksrc}/build/hyprland.pc 644 usr/share/pkgconfig
    vinstall ${wrksrc}/build/hyprland.pc 644 usr/lib/pkgconfig
}

hyprland-devel_package() {
	short_desc="Dynamic tiling Wayland compositor - development files"
	depends="${sourcepkg}>=${version}_${revision} ${makedepends}"
	pkg_install() {
		vmove usr/include
		vmove usr/share/pkgconfig
    	make -C ${wrksrc} installheaders PREFIX=/usr DESTDIR=${DESTDIR}
	}
}

configure_args="-DNO_SYSTEMD=ON -DUSE_NATIVE_EMBED=OFF -DCMAKE_BUILD_TYPE=Release -DCMAKE_BUILD_WITH_INSTALL_RPATH=ON"
hostmakedepends="cmake pkg-config autoconf git cpio glslang jq make ninja lua55"
makedepends="
	hyprgraphics
	hyprcursor-devel
	hyprutils-devel
	aquamarine-devel
	hyprlang-devel
	hyprland-protocols
	hyprwayland-scanner
	tomlplusplus-devel

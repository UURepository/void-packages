# Template file for 'hyprlock'
pkgname=hyprlock
version=0.9.5
revision=1
build_style=cmake
configure_args=" --no-warn-unused-cli -DCMAKE_BUILD_TYPE=Release"
hostmakedepends="cmake pkg-config"
makedepends="
	hyprwayland-scanner
	hyprgraphics
	hyprlang-devel
	hyprutils-devel
	sdbus-c++-devel
	elogind-devel
	cairo-devel
	libdrm-devel
	libxkbcommon-devel
	MesaLib-devel
	pango-devel
	pam-devel
	wayland-devel 
	wayland-protocols 
	libjpeg-turbo-devel
	libwebp-devel
	file-devel
"
short_desc="Hyprland's GPU-accelerated screen locking utility"
maintainer="hesam-init <hesam.init@gmail.com>"
license="BSD-3-Clause"
homepage="https://github.com/hyprwm/hyprlock"
changelog="https://github.com/hyprwm/hyprlock/releases"
distfiles="https://github.com/hyprwm/hyprlock/archive/refs/tags/v${version}.tar.gz"
checksum=cbc49fc5553c550131e1a15089847501de42579944814229bfa9f8ea18519f89

build_options="clang gcc"
build_options_default="clang"
desc_option_clang="Use clang to build"
desc_option_gcc="Use gcc to build"

if [ "$build_option_gcc" ]; then
	hostmakedepends+=" gcc"
	makedepends+=" libgcc-devel fmt-devel"
fi

if [ "$build_option_clang" ]; then
	hostmakedepends+=" clang21"
	makedepends+=""
fi

_apply_patch() {
	local args="$1" pname="$(basename $2)"

	if [ ! -f ".${pname}_done" ]; then
		patch -N $args -i $2
		touch .${pname}_done
	fi
}

pre_configure() {
	#if [ "$build_option_gcc" ]; then
	#  _apply_patch -p1 ${FILESDIR}/gcc.patch
	#fi

	if [ "$build_option_clang" ]; then
		export CC=clang
		export CXX=clang++

		configure_args+=" -DCMAKE_C_COMPILER=$CC -DCMAKE_CXX_COMPILER=$CXX -DCMAKE_CXX_STANDARD=23 -DCMAKE_CXX_FLAGS=-stdlib=libstdc++ -DCMAKE_EXE_LINKER_FLAGS=-stdlib=libstdc++ -DCMAKE_SHARED_LINKER_FLAGS=-stdlib=libstdc++"
	fi
}

post_install() {
	vlicense LICENSE
}

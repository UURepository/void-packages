# Template file for 'xdg-desktop-portal-hyprland'
pkgname=xdg-desktop-portal-hyprland
version=1.3.12
revision=1
build_style=cmake
configure_args=" --no-warn-unused-cli -DSYSTEMD_SERVICES=OFF -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_LIBEXECDIR=/usr/lib"
hostmakedepends="cmake pkg-config"
makedepends="
	hyprlang-devel
	hyprutils-devel
	hyprland-protocols
	hyprwayland-scanner
	sdbus-c++-devel
	wayland-devel
	wayland-protocols
	pipewire-devel
	libpipewire
	libgbm-devel
	libdrm-devel
	elogind-devel
	qt6-base-devel
"
depends="
	hyprlang
	hyprutils
	hyprland-protocols
	hyprwayland-scanner
	sdbus-c++
	xdg-desktop-portal
	pipewire
	qt6-base
	qt6-wayland
"
short_desc="Backend of xdg-desktop-portal for Hyprland"
maintainer="hesam-init <hesam.init@gmail.com>"
license="BSD-3-Clause"
homepage="https://github.com/hyprwm/xdg-desktop-portal-hyprland"
distfiles="https://github.com/hyprwm/xdg-desktop-portal-hyprland/archive/refs/tags/v${version}.tar.gz"
checksum=c30ffe6ce9569a222438cb403d426a58c84e3653f19c8de641673097a9acc3b0

build_options="clang gcc"
build_options_default="clang"
desc_option_clang="Use clang to build"
desc_option_gcc="Use gcc to build"

if [ "$build_option_gcc" ]; then
	hostmakedepends+=" gcc"
	makedepends+=" libgcc-devel fmt-devel"
fi

if [ "$build_option_clang" ]; then
	hostmakedepends+=" clang21"
	makedepends+=""
fi

pre_configure() {
	if [ "$build_option_clang" ]; then
		export CC=clang
		export CXX=clang++

		configure_args+=" -DCMAKE_C_COMPILER=$CC -DCMAKE_CXX_COMPILER=$CXX -DCMAKE_CXX_STANDARD=23 -DCMAKE_CXX_FLAGS=-stdlib=libstdc++ -DCMAKE_EXE_LINKER_FLAGS=-stdlib=libstdc++ -DCMAKE_SHARED_LINKER_FLAGS=-stdlib=libstdc++"
	fi
}

post_install() {
	vlicense LICENSE
}
